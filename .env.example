# MongoDB — use local Docker for dev (npm run docker:up), or Atlas for production
# Local (recommended for dev):
MONGODB_URI=mongodb://127.0.0.1:27017/ott_platform
# Atlas (whitelist your IP under Network Access in Atlas):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster....mongodb.net/ott_platform?retryWrites=true&w=majority

# Redis (BullMQ transcode queue)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Express
PORT=5000
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# S3 / MinIO (VOD + HLS segments)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ott-media
CDN_BASE_URL=http://localhost:9000/ott-media

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# DRM
DRM_LICENSE_URL=
DRM_KEY_ID=

# FFmpeg worker
FFMPEG_PATH=ffmpeg
TRANSCODE_OUTPUT_DIR=./transcoded
WORKER_SECRET=dev-worker

# Live ingest (RTMP server URL)
LIVE_INGEST_URL=rtmp://localhost:1935/live

# React (optional — Vite proxy uses /api by default)
VITE_API_URL=

# Firebase Client SDK Configuration (Frontend)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Admin SDK Configuration (Backend)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

